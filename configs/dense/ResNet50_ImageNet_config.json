{
    "model": {
        "name": "ResNet50_IN",
        "parameters": {
            "num_classes": 100
        }
    },
    "training": {
        "learning_rate": 0.1,
        "epochs": 90,
        "optimizer": "sgd",
        "loss_function": "cross_entropy",
        "scheduler": {
            "type": "MultiStepLR",
            "step_size": [30, 60, 80],
            "gamma": 0.1
        },
        "weight_decay": 0.0001,
        "momentum": 0.9,
        "rho": 0.05
    },
    "dataset": {
        "name": "ImageNet",
        "root": "/home/datzeni/SAM_for_Sparse_NN/src/data/DATA/Imagenet_imagefolder",
        "batch_size": 64
    },
    "save_every": 10,
    "evaluate_flatness_every": 10,
    "eval_batches": 5
}
