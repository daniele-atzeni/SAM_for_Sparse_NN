{
    "model": {
        "name": "ViT",
        "parameters": {
            "image_size": 784,
            "patch_size": 32,
            "num_classes": 10,
            "dim": 1024,
            "depth": 6,
            "heads": 16,
            "mlp_dim": 2048,
            "dropout": 0.1,
            "emb_dropout": 0.1
        }
    },
    "training": {
        "learning_rate": 0.05,
        "batch_size": 64,
        "epochs": 20,
        "optimizer": "sgd", 
        "loss_function": "cross_entropy"
    },
    "regularization": {
        "dropout_rate": 0.5,
        "weight_decay": 0.0001,
        "batch_normalization": true
    },
    "hyperparameters": {
        "momentum": 0.9,
        "beta1": 0.9,
        "beta2": 0.999,
        "epsilon": 1e-8
    }
}