{
    "model": {
        "name": "ViT",
        "parameters": {
            "image_size": 32,
            "patch_size": 4,
            "num_classes": 10,
            "dim": 256,
            "depth": 6,
            "heads": 8,
            "mlp_dim": 512,
            "pool": "cls",
            "channels": 3,
            "dim_head": 32,
            "dropout": 0.1,
            "emb_dropout": 0.1
        }
    },
    "training": {
        "learning_rate": 0.003,
        "epochs": 300,
        "optimizer": "adamw",
        "loss_function": "cross_entropy",
        "scheduler": {
            "type": "WarmupCosineAnnealingLR",
            "T_max": 200,
            "warmup_epochs": 10
        },
        "weight_decay": 0.3,
        "rho": 0.5
    },
    "dataset": {
        "name": "cifar10",
        "batch_size": 128
    },
    "evaluate_flatness_every": 10,
    "save_every": 180,
    "first_iter": 15,
    "prune_every": 10,
    "prune_ratio": 0.3,
    "n_iter": 5
}